---
import { Image } from "astro:assets";
import swimCover from "../assets/images/swim-cover.png";
import Icon from "../components/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const lyricLines = [
  { text: "何億通り 奪い合って ひかり射した", active: false },
  { text: "何億光年 今日に向かって放浪を", active: true },
  { text: "何億通り 奪い合って ひかり射した", active: false },
  { text: "悩んでる 君の好きな方へ 泳いで", active: false },
];

const initialLyricIndex = Math.max(
  0,
  lyricLines.findIndex((line) => line.active),
);
const initialLyricId = `swim-lyric-${initialLyricIndex + 1}`;
---

<BaseLayout
  title="关于 · Swim"
  description="在《Swim》的蓝色里，留下一小段关于本站之外的话。"
  overlayHeader
  hideFooter
  bodyClass="about-page"
>
  <main id="main-content" class="about" tabindex="-1">
    <section class="swim-scene" aria-labelledby="about-title">
      <div class="swim-scene__backdrop" aria-hidden="true">
        <Image
          class="swim-scene__backdrop-image"
          src={swimCover}
          alt=""
          widths={[640, 960, 1280]}
          sizes="100vw"
          format="webp"
          quality={48}
          loading="eager"
          decoding="async"
        />
      </div>

      <h1 id="about-title" class="visually-hidden">关于本站</h1>

      <div class="swim-scene__stage">
        <figure class="swim-cover">
          <div class="swim-cover__frame">
            <Image
              class="swim-cover__image"
              src={swimCover}
              alt="《Swim》翻唱封面，五位角色站在蓝天与白云前"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1219px) min(calc(100vw - 40px), 760px), min(47vw, 900px)"
              format="webp"
              quality={86}
              priority
            />
            <a
              class="swim-cover__play"
              href="https://www.bilibili.com/video/BV1CN4y1u7Ub/"
              aria-label="在哔哩哔哩播放《SWIM (MyGO!!!!! ver)》"
            >
              <span class="swim-cover__play-label" aria-hidden="true">Play</span>
              <span class="swim-cover__play-icon" aria-hidden="true">
                <Icon name="bilibili" size={22} strokeWidth={1.7} />
              </span>
            </a>
          </div>
          <figcaption
            class="swim-cover__caption"
            aria-label="SWIM(MyGO!!!!! ver)"
          >
            <span class="swim-cover__title">SWIM</span>
            <span class="swim-cover__version">(MyGO!!!!! ver)</span>
          </figcaption>
        </figure>

        <div class="swim-lyrics" data-lyrics>
          <div
            class="swim-lyrics__viewport"
            role="region"
            aria-label="日文歌词，可上下滚动"
            aria-activedescendant={initialLyricId}
            tabindex="0"
            data-lyrics-viewport
          >
            <blockquote class="swim-lyrics__quote" lang="ja">
              <ol class="swim-lyrics__track" data-lyrics-track>
                {
                  lyricLines.map((line, index) => (
                    <li
                      class:list={[
                        "swim-lyrics__item",
                        { "is-active": line.active },
                      ]}
                      data-lyric-item
                      data-initial-active={line.active ? "true" : undefined}
                    >
                      <button
                        id={`swim-lyric-${index + 1}`}
                        class="swim-lyrics__line"
                        type="button"
                        aria-current={line.active ? "true" : undefined}
                        tabindex="-1"
                        data-lyric-line
                      >
                        {line.text}
                      </button>
                    </li>
                  ))
                }
              </ol>
            </blockquote>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>("[data-lyrics]").forEach((root) => {
    if (root.dataset.lyricsReady === "true") return;
    root.dataset.lyricsReady = "true";

    const viewport = root.querySelector<HTMLElement>("[data-lyrics-viewport]");
    const track = root.querySelector<HTMLElement>("[data-lyrics-track]");
    const items = Array.from(
      root.querySelectorAll<HTMLElement>("[data-lyric-item]"),
    );

    if (!viewport || !track || items.length === 0) return;

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const initialItem =
      items.find((item) => item.dataset.initialActive === "true") ?? items[0];
    let activeItem = initialItem;
    let lyricsInitialized = false;
    let scrollFrame = 0;
    let resizeFrame = 0;

    const updateTrackPadding = () => {
      const firstItem = items[0];
      const lastItem = items.at(-1);
      if (!firstItem || !lastItem) return;

      track.style.setProperty(
        "--lyrics-padding-start",
        `${Math.max(0, (viewport.clientHeight - firstItem.offsetHeight) / 2)}px`,
      );
      track.style.setProperty(
        "--lyrics-padding-end",
        `${Math.max(0, (viewport.clientHeight - lastItem.offsetHeight) / 2)}px`,
      );
    };

    const setActiveItem = (nextItem: HTMLElement) => {
      activeItem = nextItem;

      items.forEach((item) => {
        const isActive = item === nextItem;
        const line = item.querySelector<HTMLButtonElement>("[data-lyric-line]");
        item.classList.toggle("is-active", isActive);

        if (!line) return;
        if (isActive) {
          line.setAttribute("aria-current", "true");
          viewport.setAttribute("aria-activedescendant", line.id);
        } else {
          line.removeAttribute("aria-current");
        }
      });
    };

    const findCenteredItem = () => {
      const viewportRect = viewport.getBoundingClientRect();
      const viewportCenter = viewportRect.top + viewportRect.height / 2;

      return items.reduce((nearest, item) => {
        const itemRect = item.getBoundingClientRect();
        const nearestRect = nearest.getBoundingClientRect();
        const itemDistance = Math.abs(
          itemRect.top + itemRect.height / 2 - viewportCenter,
        );
        const nearestDistance = Math.abs(
          nearestRect.top + nearestRect.height / 2 - viewportCenter,
        );
        return itemDistance < nearestDistance ? item : nearest;
      }, items[0]);
    };

    const syncActiveItem = () => {
      scrollFrame = 0;
      setActiveItem(findCenteredItem());
    };

    const centerItem = (
      item: HTMLElement,
      behavior: ScrollBehavior = reducedMotion.matches ? "auto" : "smooth",
    ) => {
      const viewportRect = viewport.getBoundingClientRect();
      const itemRect = item.getBoundingClientRect();
      const top =
        viewport.scrollTop +
        itemRect.top -
        viewportRect.top -
        (viewport.clientHeight - itemRect.height) / 2;

      viewport.scrollTo({ top, behavior });
    };

    viewport.addEventListener(
      "scroll",
      () => {
        if (!lyricsInitialized || scrollFrame) return;
        scrollFrame = window.requestAnimationFrame(syncActiveItem);
      },
      { passive: true },
    );

    items.forEach((item) => {
      item
        .querySelector<HTMLButtonElement>("[data-lyric-line]")
        ?.addEventListener("click", () => {
          setActiveItem(item);
          centerItem(item);
          viewport.focus({ preventScroll: true });
        });
    });

    viewport.addEventListener("keydown", (event) => {
      const handledKeys = ["ArrowDown", "ArrowUp", "Home", "End"];
      if (!handledKeys.includes(event.key)) return;

      event.preventDefault();
      const currentIndex = Math.max(0, items.indexOf(activeItem));
      let nextIndex = currentIndex;

      if (event.key === "ArrowDown") nextIndex = Math.min(items.length - 1, currentIndex + 1);
      if (event.key === "ArrowUp") nextIndex = Math.max(0, currentIndex - 1);
      if (event.key === "Home") nextIndex = 0;
      if (event.key === "End") nextIndex = items.length - 1;
      const nextItem = items[nextIndex];
      setActiveItem(nextItem);
      centerItem(nextItem);
    });

    const refreshLayout = () => {
      resizeFrame = 0;
      if (scrollFrame) {
        window.cancelAnimationFrame(scrollFrame);
        scrollFrame = 0;
      }

      const targetItem = lyricsInitialized ? activeItem : initialItem;
      updateTrackPadding();
      setActiveItem(targetItem);
      centerItem(targetItem, "auto");
      lyricsInitialized = true;
    };

    const requestLayoutRefresh = () => {
      if (resizeFrame) window.cancelAnimationFrame(resizeFrame);
      resizeFrame = window.requestAnimationFrame(refreshLayout);
    };

    const resizeObserver = new ResizeObserver(requestLayoutRefresh);
    resizeObserver.observe(viewport);
    items.forEach((item) => resizeObserver.observe(item));

    requestLayoutRefresh();
    document.fonts?.ready.then(requestLayoutRefresh);
  });
</script>

<style>
  :global(body.about-page) {
    background: #030817;
  }

  :global(body.about-page :focus-visible) {
    outline-color: #ffffff;
    box-shadow: 0 0 0 4px rgba(3, 8, 23, 0.78);
  }

  .about {
    min-height: 100svh;
    scroll-margin-top: var(--header-height);
    background: #030817;
    color: #f8faff;
    font-family:
      "Yu Gothic", YuGothic, "Hiragino Kaku Gothic ProN", "Noto Sans JP",
      sans-serif;
    outline: none;
  }

  .swim-scene {
    position: relative;
    display: grid;
    min-height: 100svh;
    overflow: hidden;
    padding:
      calc(var(--header-height) + clamp(28px, 5vh, 64px))
      clamp(24px, 5.5vw, 96px)
      clamp(38px, 6vh, 78px);
    isolation: isolate;
  }

  .swim-scene::before,
  .swim-scene::after {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    content: "";
  }

  .swim-scene::before {
    background:
      linear-gradient(
        180deg,
        rgba(1, 5, 18, 0.7) 0,
        rgba(1, 5, 18, 0.12) 25%,
        rgba(1, 5, 18, 0.2) 66%,
        rgba(1, 5, 18, 0.62) 100%
      ),
      linear-gradient(
        96deg,
        rgba(3, 9, 27, 0.3) 0%,
        rgba(3, 9, 27, 0.42) 48%,
        rgba(3, 7, 22, 0.78) 100%
      );
  }

  .swim-scene::after {
    z-index: -1;
    background:
      radial-gradient(circle at 77% 42%, rgba(72, 129, 255, 0.14), transparent 30%),
      radial-gradient(circle at 19% 78%, rgba(255, 126, 160, 0.08), transparent 26%);
    mix-blend-mode: screen;
    opacity: 0.8;
  }

  .swim-scene__backdrop {
    position: absolute;
    inset: -72px;
    z-index: -3;
    overflow: hidden;
    pointer-events: none;
    background: #052b91;
  }

  .swim-scene__backdrop-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 44%;
    filter: blur(46px) saturate(1.18) brightness(0.48);
    transform: scale(1.1);
    animation: backdrop-settle 1.6s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  .swim-scene__stage {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(100%, 1760px);
    margin: auto;
    grid-template-columns: minmax(520px, 1.04fr) minmax(500px, 1fr);
    align-items: center;
    gap: clamp(40px, 3.5vw, 72px);
  }

  .swim-cover {
    width: min(100%, 900px);
    min-width: 0;
    margin: 0;
    justify-self: start;
    opacity: 0;
    transform: translateY(22px) scale(0.985);
    animation: cover-arrive 900ms 90ms cubic-bezier(0.2, 0.75, 0.2, 1) forwards;
  }

  .swim-cover__frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3344 / 1882;
    border-radius: clamp(14px, 1.4vw, 24px);
    background: #063fc6;
    box-shadow:
      0 42px 110px rgba(0, 3, 18, 0.56),
      0 14px 32px rgba(0, 5, 24, 0.38);
  }

  .swim-cover__frame::after {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: inherit;
    pointer-events: none;
    content: "";
  }

  .swim-cover__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 900ms cubic-bezier(0.2, 0.75, 0.2, 1);
  }

  .swim-cover__frame:hover .swim-cover__image {
    transform: scale(1.012);
  }

  .swim-cover__play {
    position: absolute;
    right: clamp(14px, 1.3vw, 20px);
    bottom: clamp(14px, 1.3vw, 20px);
    z-index: 2;
    display: flex;
    width: 50px;
    height: 50px;
    box-sizing: border-box;
    padding-inline: 13px;
    overflow: hidden;
    align-items: center;
    justify-content: flex-end;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 999px;
    background: rgba(3, 8, 23, 0.76);
    box-shadow:
      0 12px 34px rgba(0, 4, 22, 0.36),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    color: #ffffff;
    text-decoration: none;
    backdrop-filter: blur(16px) saturate(1.25);
    -webkit-backdrop-filter: blur(16px) saturate(1.25);
    transform-origin: right center;
    transition:
      width 380ms cubic-bezier(0.2, 0.75, 0.2, 1),
      background-color 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease,
      transform 160ms ease;
  }

  .swim-cover__play-label {
    max-width: 0;
    margin-right: 0;
    overflow: hidden;
    font-family: var(--font-serif);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.055em;
    line-height: 1;
    opacity: 0;
    transform: translateX(7px);
    white-space: nowrap;
    transition:
      max-width 320ms cubic-bezier(0.2, 0.75, 0.2, 1),
      margin-right 320ms cubic-bezier(0.2, 0.75, 0.2, 1),
      opacity 180ms ease,
      transform 320ms cubic-bezier(0.2, 0.75, 0.2, 1);
  }

  .swim-cover__play-icon {
    display: grid;
    flex: 0 0 22px;
    place-items: center;
    pointer-events: none;
  }

  .swim-cover__play:focus-visible {
    width: 112px;
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(0, 174, 236, 0.88);
    box-shadow:
      0 14px 40px rgba(0, 174, 236, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .swim-cover__play:focus-visible .swim-cover__play-label {
    max-width: 42px;
    margin-right: 10px;
    opacity: 1;
    transform: none;
  }

  .swim-cover__play:active {
    transform: scale(0.965);
  }

  @media (hover: hover) and (pointer: fine) {
    .swim-cover__play:hover {
      width: 112px;
      border-color: rgba(255, 255, 255, 0.5);
      background: rgba(0, 174, 236, 0.88);
      box-shadow:
        0 14px 40px rgba(0, 174, 236, 0.24),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    .swim-cover__play:hover .swim-cover__play-label {
      max-width: 42px;
      margin-right: 10px;
      opacity: 1;
      transform: none;
    }
  }

  .swim-cover__caption {
    display: grid;
    width: max-content;
    margin: 15px 0 0 3px;
    padding-left: 12px;
    border-left: 1px solid rgba(131, 184, 255, 0.7);
    color: rgba(255, 255, 255, 0.92);
    font-family: var(--font-serif);
    line-height: 1.1;
    gap: 3px;
  }

  .swim-cover__title {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.09em;
  }

  .swim-cover__version {
    color: rgba(255, 255, 255, 0.62);
    font-size: 11px;
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.055em;
  }

  .swim-lyrics {
    position: relative;
    width: 100%;
    height: clamp(360px, 52svh, 580px);
    min-width: 0;
    max-width: none;
    align-self: center;
    opacity: 0;
    transform: translateY(18px);
    animation: lyrics-arrive 850ms 180ms cubic-bezier(0.2, 0.75, 0.2, 1) forwards;
  }

  .swim-lyrics__viewport {
    position: relative;
    width: 100%;
    height: 100%;
    padding-inline: 6px 18px;
    overflow-x: hidden;
    overflow-y: auto;
    scroll-behavior: smooth;
    scroll-snap-type: y proximity;
    scrollbar-width: none;
    touch-action: pan-y;
    -webkit-overflow-scrolling: touch;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 15%,
      #000 85%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 15%,
      #000 85%,
      transparent 100%
    );
  }

  .swim-lyrics__viewport::-webkit-scrollbar {
    width: 0;
    height: 0;
  }

  .swim-lyrics__quote {
    margin: 0;
  }

  .swim-lyrics__track {
    --lyrics-padding-start: 40%;
    --lyrics-padding-end: 40%;

    display: flex;
    margin: 0;
    padding:
      var(--lyrics-padding-start)
      0
      var(--lyrics-padding-end);
    flex-direction: column;
    gap: clamp(8px, 1.2vh, 16px);
    list-style: none;
  }

  .swim-lyrics__item {
    min-width: 0;
    scroll-snap-align: center;
  }

  .swim-lyrics__line {
    width: 100%;
    margin: 0;
    padding: clamp(14px, 2.1vh, 24px) 0;
    border: 0;
    background: transparent;
    color: #edf3ff;
    font: inherit;
    font-size: clamp(2rem, 2.3vw, 3.35rem);
    font-weight: 750;
    letter-spacing: -0.035em;
    line-height: 1.28;
    text-align: left;
    text-wrap: balance;
    line-break: strict;
    overflow-wrap: anywhere;
    opacity: 0.44;
    transform: scale(0.975);
    transform-origin: left center;
    transition:
      color 360ms ease,
      opacity 360ms ease,
      text-shadow 360ms ease,
      transform 420ms cubic-bezier(0.2, 0.75, 0.2, 1);
  }

  .swim-lyrics__line:hover {
    opacity: 0.72;
  }

  .swim-lyrics__item.is-active .swim-lyrics__line {
    color: #ffffff;
    opacity: 1;
    transform: scale(1);
    text-shadow: 0 16px 54px rgba(175, 210, 255, 0.26);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @keyframes backdrop-settle {
    from {
      filter: blur(62px) saturate(1.06) brightness(0.34);
      transform: scale(1.16);
    }

    to {
      filter: blur(46px) saturate(1.18) brightness(0.48);
      transform: scale(1.1);
    }
  }

  @keyframes cover-arrive {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes lyrics-arrive {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1219px) {
    .swim-scene {
      overflow: clip;
      padding:
        calc(var(--header-height) + 38px)
        clamp(20px, 6vw, 54px)
        clamp(42px, 7vh, 70px);
    }

    .swim-scene::before {
      background:
        linear-gradient(
          180deg,
          rgba(1, 5, 18, 0.72) 0,
          rgba(1, 5, 18, 0.18) 23%,
          rgba(2, 7, 23, 0.58) 56%,
          rgba(2, 7, 23, 0.86) 100%
        ),
        linear-gradient(90deg, rgba(3, 9, 27, 0.35), rgba(3, 7, 22, 0.55));
    }

    .swim-scene__stage {
      grid-template-columns: minmax(0, 1fr);
      gap: clamp(34px, 6vh, 58px);
    }

    .swim-cover,
    .swim-lyrics {
      width: min(100%, 760px);
      margin-inline: auto;
      justify-self: center;
    }

    .swim-lyrics {
      height: clamp(320px, 48svh, 500px);
      max-width: 760px;
    }

    .swim-lyrics__line {
      font-size: clamp(2rem, 5.2vw, 3.2rem);
    }
  }

  @media (max-width: 520px) {
    .swim-scene {
      padding:
        calc(var(--header-height) + 28px)
        20px
        40px;
    }

    .swim-cover__frame {
      border-radius: 12px;
    }

    .swim-cover__play {
      right: 10px;
      bottom: 10px;
      width: 44px;
      height: 44px;
      padding-inline: 11px;
    }

    .swim-cover__play-icon {
      flex-basis: 20px;
      transform: scale(0.91);
    }

    .swim-cover__caption {
      margin-top: 12px;
      padding-left: 10px;
    }

    .swim-cover__title {
      font-size: 14px;
    }

    .swim-cover__version {
      font-size: 9.5px;
    }

    .swim-lyrics {
      height: clamp(300px, 48svh, 390px);
    }

    .swim-lyrics__viewport {
      padding-inline: 2px 8px;
    }

    .swim-lyrics__line {
      padding-block: 12px;
      font-size: clamp(1.65rem, 7.4vw, 2.4rem);
      line-height: 1.24;
    }
  }

  @media (max-height: 620px) and (min-width: 1220px) {
    .swim-scene {
      align-items: start;
      padding-top: calc(var(--header-height) + 22px);
      padding-bottom: 28px;
    }

    .swim-scene__stage {
      gap: clamp(42px, 6vw, 86px);
    }

    .swim-lyrics {
      height: 330px;
    }

    .swim-lyrics__line {
      padding-block: 12px;
      font-size: clamp(1.9rem, 2.7vw, 3.2rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .swim-scene__backdrop-image,
    .swim-cover,
    .swim-lyrics {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .swim-lyrics__viewport {
      scroll-behavior: auto;
    }

    .swim-lyrics__line {
      transform: none;
      transition: none;
    }

    .swim-cover__image,
    .swim-cover__play,
    .swim-cover__play-label {
      transition: none;
    }
  }
</style>
