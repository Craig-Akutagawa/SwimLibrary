---
import { Image } from "astro:assets";
import swimCover from "../assets/images/swim-cover.png";
import BaseLayout from "../layouts/BaseLayout.astro";

// Placeholder copy: replace these three lines with the final lyrics later.
const lyricLines = [
  { text: "青い夜を泳いで", active: false },
  { text: "明日へ泳いで", active: true },
  { text: "この声が届くまで", active: false },
];
---

<BaseLayout
  title="关于 · Swim"
  description="在《Swim》的蓝色里，留下一小段关于本站之外的话。"
  overlayHeader
  hideFooter
  bodyClass="about-page"
>
  <main id="main-content" class="about" tabindex="-1">
    <section class="swim-scene" aria-labelledby="about-title">
      <div class="swim-scene__backdrop" aria-hidden="true">
        <Image
          class="swim-scene__backdrop-image"
          src={swimCover}
          alt=""
          widths={[640, 960, 1280]}
          sizes="100vw"
          format="webp"
          quality={48}
          loading="eager"
          decoding="async"
        />
      </div>

      <h1 id="about-title" class="visually-hidden">关于本站</h1>

      <div class="swim-scene__stage">
        <figure class="swim-cover">
          <div class="swim-cover__frame">
            <Image
              class="swim-cover__image"
              src={swimCover}
              alt="《Swim》翻唱封面，五位角色站在蓝天与白云前"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 900px) calc(100vw - 40px), min(58vw, 980px)"
              format="webp"
              quality={86}
              priority
            />
          </div>
          <figcaption class="swim-cover__caption">
            <span class="swim-cover__title">Swim</span>
            <span>MyGO!!!!! cover</span>
          </figcaption>
        </figure>

        <div class="swim-lyrics">
          <p class="swim-lyrics__label">
            <span aria-hidden="true"></span>
            About / selected lyrics
          </p>

          <blockquote
            class="swim-lyrics__lines"
            lang="ja"
            aria-label="日文歌词节选，占位文本"
          >
            {
              lyricLines.map((line, index) => (
                <p
                  class:list={[
                    "swim-lyrics__line",
                    { "swim-lyrics__line--active": line.active },
                  ]}
                  style={`--line-delay: ${260 + index * 110}ms`}
                >
                  {line.text}
                </p>
              ))
            }
          </blockquote>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body.about-page) {
    background: #030817;
  }

  :global(body.about-page :focus-visible) {
    outline-color: #ffffff;
    box-shadow: 0 0 0 4px rgba(3, 8, 23, 0.78);
  }

  .about {
    min-height: 100svh;
    scroll-margin-top: var(--header-height);
    background: #030817;
    color: #f8faff;
    font-family:
      "Yu Gothic", YuGothic, "Hiragino Kaku Gothic ProN", "Noto Sans JP",
      sans-serif;
    outline: none;
  }

  .swim-scene {
    position: relative;
    display: grid;
    min-height: 100svh;
    overflow: hidden;
    padding:
      calc(var(--header-height) + clamp(28px, 5vh, 64px))
      clamp(24px, 5.5vw, 96px)
      clamp(38px, 6vh, 78px);
    isolation: isolate;
  }

  .swim-scene::before,
  .swim-scene::after {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    content: "";
  }

  .swim-scene::before {
    background:
      linear-gradient(
        180deg,
        rgba(1, 5, 18, 0.7) 0,
        rgba(1, 5, 18, 0.12) 25%,
        rgba(1, 5, 18, 0.2) 66%,
        rgba(1, 5, 18, 0.62) 100%
      ),
      linear-gradient(
        96deg,
        rgba(3, 9, 27, 0.3) 0%,
        rgba(3, 9, 27, 0.42) 48%,
        rgba(3, 7, 22, 0.78) 100%
      );
  }

  .swim-scene::after {
    z-index: -1;
    background:
      radial-gradient(circle at 77% 42%, rgba(72, 129, 255, 0.14), transparent 30%),
      radial-gradient(circle at 19% 78%, rgba(255, 126, 160, 0.08), transparent 26%);
    mix-blend-mode: screen;
    opacity: 0.8;
  }

  .swim-scene__backdrop {
    position: absolute;
    inset: -72px;
    z-index: -3;
    overflow: hidden;
    pointer-events: none;
    background: #052b91;
  }

  .swim-scene__backdrop-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 44%;
    filter: blur(46px) saturate(1.18) brightness(0.48);
    transform: scale(1.1);
    animation: backdrop-settle 1.6s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  .swim-scene__stage {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(100%, 1540px);
    margin: auto;
    grid-template-columns: minmax(0, 1.52fr) minmax(340px, 0.72fr);
    align-items: center;
    gap: clamp(48px, 7vw, 120px);
  }

  .swim-cover {
    min-width: 0;
    margin: 0;
    opacity: 0;
    transform: translateY(22px) scale(0.985);
    animation: cover-arrive 900ms 90ms cubic-bezier(0.2, 0.75, 0.2, 1) forwards;
  }

  .swim-cover__frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3344 / 1882;
    border-radius: clamp(14px, 1.4vw, 24px);
    background: #063fc6;
    box-shadow:
      0 42px 110px rgba(0, 3, 18, 0.56),
      0 14px 32px rgba(0, 5, 24, 0.38);
  }

  .swim-cover__frame::after {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: inherit;
    pointer-events: none;
    content: "";
  }

  .swim-cover__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 900ms cubic-bezier(0.2, 0.75, 0.2, 1);
  }

  .swim-cover__frame:hover .swim-cover__image {
    transform: scale(1.012);
  }

  .swim-cover__caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    margin-top: 17px;
    color: rgba(244, 248, 255, 0.58);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .swim-cover__title {
    color: rgba(255, 255, 255, 0.92);
    font-size: 13px;
    letter-spacing: 0.16em;
  }

  .swim-lyrics {
    min-width: 0;
    max-width: 570px;
    align-self: center;
  }

  .swim-lyrics__label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 clamp(38px, 5.5vh, 68px);
    color: rgba(236, 243, 255, 0.62);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.19em;
    text-transform: uppercase;
    opacity: 0;
    animation: lyric-label-in 700ms 170ms ease-out forwards;
  }

  .swim-lyrics__label span {
    width: 32px;
    height: 1px;
    background: rgba(236, 243, 255, 0.55);
  }

  .swim-lyrics__lines {
    display: grid;
    margin: 0;
    gap: clamp(21px, 3.2vh, 38px);
  }

  .swim-lyrics__line {
    --line-opacity: 0.48;

    margin: 0;
    color: #edf3ff;
    font-size: clamp(2.15rem, 3.2vw, 4.35rem);
    font-weight: 750;
    letter-spacing: -0.035em;
    line-height: 1.28;
    text-wrap: balance;
    opacity: 0;
    transform: translateY(24px);
    animation: lyric-line-in 800ms var(--line-delay) cubic-bezier(0.2, 0.75, 0.2, 1) forwards;
  }

  .swim-lyrics__line--active {
    --line-opacity: 1;

    color: #ffffff;
    text-shadow: 0 16px 54px rgba(175, 210, 255, 0.26);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @keyframes backdrop-settle {
    from {
      filter: blur(62px) saturate(1.06) brightness(0.34);
      transform: scale(1.16);
    }

    to {
      filter: blur(46px) saturate(1.18) brightness(0.48);
      transform: scale(1.1);
    }
  }

  @keyframes cover-arrive {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes lyric-label-in {
    to {
      opacity: 1;
    }
  }

  @keyframes lyric-line-in {
    to {
      opacity: var(--line-opacity);
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .swim-scene {
      overflow: clip;
      padding:
        calc(var(--header-height) + 38px)
        clamp(20px, 6vw, 54px)
        clamp(42px, 7vh, 70px);
    }

    .swim-scene::before {
      background:
        linear-gradient(
          180deg,
          rgba(1, 5, 18, 0.72) 0,
          rgba(1, 5, 18, 0.18) 23%,
          rgba(2, 7, 23, 0.58) 56%,
          rgba(2, 7, 23, 0.86) 100%
        ),
        linear-gradient(90deg, rgba(3, 9, 27, 0.35), rgba(3, 7, 22, 0.55));
    }

    .swim-scene__stage {
      grid-template-columns: minmax(0, 1fr);
      gap: clamp(34px, 6vh, 58px);
    }

    .swim-cover,
    .swim-lyrics {
      width: min(100%, 760px);
      margin-inline: auto;
    }

    .swim-lyrics {
      max-width: 680px;
    }

    .swim-lyrics__label {
      margin-bottom: 30px;
    }

    .swim-lyrics__lines {
      gap: clamp(18px, 3vh, 28px);
    }

    .swim-lyrics__line {
      font-size: clamp(2.2rem, 8.5vw, 4.25rem);
    }
  }

  @media (max-width: 520px) {
    .swim-scene {
      padding:
        calc(var(--header-height) + 28px)
        20px
        40px;
    }

    .swim-cover__frame {
      border-radius: 12px;
    }

    .swim-cover__caption {
      margin-top: 12px;
      font-size: 9px;
      letter-spacing: 0.1em;
    }

    .swim-cover__title {
      font-size: 11px;
    }

    .swim-lyrics__label {
      margin-bottom: 25px;
      font-size: 9px;
    }

    .swim-lyrics__line {
      font-size: clamp(2rem, 10.6vw, 3rem);
      line-height: 1.24;
    }
  }

  @media (max-height: 620px) and (min-width: 901px) {
    .swim-scene {
      align-items: start;
      padding-top: calc(var(--header-height) + 22px);
      padding-bottom: 28px;
    }

    .swim-scene__stage {
      gap: clamp(42px, 6vw, 86px);
    }

    .swim-lyrics__label {
      margin-bottom: 28px;
    }

    .swim-lyrics__lines {
      gap: 18px;
    }

    .swim-lyrics__line {
      font-size: clamp(2rem, 3vw, 3.6rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .swim-scene__backdrop-image,
    .swim-cover,
    .swim-lyrics__label,
    .swim-lyrics__line {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .swim-lyrics__line:not(.swim-lyrics__line--active) {
      opacity: var(--line-opacity);
    }

    .swim-cover__image {
      transition: none;
    }
  }
</style>
