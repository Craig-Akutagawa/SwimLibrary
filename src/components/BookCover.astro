---
interface Props {
  title: string;
  author: string;
  label: string;
  accent: string;
  size?: "small" | "regular" | "large";
}

const {
  title,
  author,
  label,
  accent,
  size = "regular",
} = Astro.props;
---

<div
  class:list={[
    "book-cover",
    {
      "book-cover--small": size === "small",
      "book-cover--large": size === "large",
    },
  ]}
  style={`--cover-bg: ${accent}; --cover-ink: #fff8e9; --cover-accent: rgba(255, 248, 233, 0.55);`}
  aria-hidden="true"
>
  <span class="book-cover__label">{label}</span>
  <strong class="book-cover__title">{title}</strong>
  <p class="book-cover__author">{author}</p>
</div>

